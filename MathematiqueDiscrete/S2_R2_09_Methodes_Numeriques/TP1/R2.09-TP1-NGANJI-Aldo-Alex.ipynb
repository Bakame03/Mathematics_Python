   "source": [
    "def Poly(P, alpha):\n",
    "    valeur = 0\n",
    "    for i in range(len(P)):\n",
    "        valeur += P[i] * (alpha**i)\n",
    "    return valeur\n",
    "\n",
    "P = [-3, 5, 2, 7, -2, 3] \n",
    "%time Poly(P, 1)"
   ]
  }
 ],
